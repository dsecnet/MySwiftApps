# Application
APP_NAME=Menzilim API
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://menzilim:menzilim_secret@localhost:5432/menzilim

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT - CHANGE THIS IN PRODUCTION
JWT_SECRET_KEY=your-super-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP Settings
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_MINUTES=15

# SMS Provider
SMS_API_KEY=
SMS_API_URL=
SMS_SENDER=Menzilim

# Apple IAP
APPLE_SHARED_SECRET=
APPLE_VERIFY_URL=https://buy.itunes.apple.com/verifyReceipt
APPLE_SANDBOX_VERIFY_URL=https://sandbox.itunes.apple.com/verifyReceipt

# File Upload
UPLOAD_DIR=uploads
MAX_IMAGE_SIZE=10485760
